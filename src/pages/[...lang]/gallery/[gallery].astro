---
import GalleryCmp from "../../../components/gallery/Gallery.astro";
import GalleryPage from "../../../components/gallery/GalleryPage.astro";
import { galleries } from "../../../data/galleries";
import Layout from "../../../layouts/Layout.astro";
import { localeParams, getLangFromUrl } from "../../../i18n/ui";

export function getStaticPaths() {
  return localeParams.flatMap((lang) =>
    galleries.map((gallery) => ({
      params: { lang, gallery: gallery.slug },
      props: { gallery },
    })),
  );
}

const { gallery } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const seo = gallery.seo[lang];
---

<Layout title={seo.title} description={seo.description}>
  <GalleryPage>
    <GalleryCmp gallery={gallery} />
  </GalleryPage>
</Layout>
