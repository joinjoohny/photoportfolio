---
import GalleryIndex from "../../components/gallery/GalleryIndex.astro";
import GalleryPage from "../../components/gallery/GalleryPage.astro";
import Layout from "../../layouts/Layout.astro";
import { localeParams, useTranslations } from "../../i18n/ui";

export function getStaticPaths() {
  return localeParams.map((lang) => ({ params: { lang } }));
}

const t = useTranslations(Astro);
---

<Layout title={t("gallery.seo.title")} description={t("gallery.seo.description")}>
  <GalleryPage>
    <GalleryIndex />
  </GalleryPage>
</Layout>
