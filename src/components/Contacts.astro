---
import { useTranslations } from "../i18n/ui";
import Eyebrow from "./Eyebrow.astro";
const t = useTranslations(Astro);
---

<section id="contacts" class="py-16 sm:py-20">
  <div class="mx-auto w-full max-w-[1170px] px-5">
    <Eyebrow num="04">
      <h2 class="font-heading text-3xl sm:text-4xl m-0 text-main-rose">
        {t("contacts.title")}
      </h2>
    </Eyebrow>
    <div class="grid gap-4 sm:grid-cols-2">
      <a
        href="https://t.me/vladisssllava"
        target="_blank"
        rel="noopener"
        class="group flex items-center gap-4 rounded-lg bg-white px-5 py-4 no-underline transition-all duration-200 hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#3e5348]/30 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
      >
        <span
          class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-[#f5f3f1] text-main-green transition-colors group-hover:bg-main-green group-hover:text-white"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
            aria-hidden="true"
          >
            <path d="M22 2 11 13"></path>
            <path d="M22 2 15 22l-4-9-9-4 20-7z"></path>
          </svg>
        </span>
        <span class="min-w-0">
          <span class="block text-[11px] uppercase tracking-[0.16em] text-muted">
            {t("contacts.telegram")}
          </span>
          <span class="block truncate text-ink">@vladisssllava</span>
        </span>
      </a>

      <a
        href="https://instagram.com/vladavada"
        target="_blank"
        rel="noopener"
        class="group flex items-center gap-4 rounded-lg bg-white px-5 py-4 no-underline transition-all duration-200 hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#3e5348]/30 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
      >
        <span
          class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-[#f5f3f1] text-main-green transition-colors group-hover:bg-main-green group-hover:text-white"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="18" height="18" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"></circle>
          </svg>
        </span>
        <span class="min-w-0">
          <span class="block text-[11px] uppercase tracking-[0.16em] text-muted">
            {t("contacts.instagram")}
          </span>
          <span class="block truncate text-ink">@vladavada</span>
        </span>
      </a>

      <a
        href="mailto:vladavadaa@gmail.com"
        class="group flex items-center gap-4 rounded-lg bg-white px-5 py-4 no-underline transition-all duration-200 hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#3e5348]/30 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
      >
        <span
          class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-[#f5f3f1] text-main-green transition-colors group-hover:bg-main-green group-hover:text-white"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
            aria-hidden="true"
          >
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <path d="m3 7 9 6 9-6"></path>
          </svg>
        </span>
        <span class="min-w-0">
          <span class="block text-[11px] uppercase tracking-[0.16em] text-muted">
            {t("contacts.email")}
          </span>
          <span class="block truncate text-ink">vladavadaa@gmail.com</span>
        </span>
      </a>

      <div
        class="flex items-center gap-4 rounded-lg bg-white px-5 py-4"
      >
        <span
          class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-[#f5f3f1] text-main-green"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
            aria-hidden="true"
          >
            <path d="M12 21s-6-5.686-6-10a6 6 0 1 1 12 0c0 4.314-6 10-6 10z"></path>
            <circle cx="12" cy="11" r="2"></circle>
          </svg>
        </span>
        <span class="min-w-0">
          <span class="block text-[11px] uppercase tracking-[0.16em] text-muted">
            {t("contacts.location")}
          </span>
          <span class="block truncate text-ink">Germany, Dresden</span>
        </span>
      </div>
    </div>
  </div>
</section>
