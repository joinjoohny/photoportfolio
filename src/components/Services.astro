---
import { useTranslations, getLangFromUrl } from "../i18n/ui";
import { services as svcContent } from "../i18n/content";
const t = useTranslations(Astro);
const lang = getLangFromUrl(Astro.url);
---

<section id="services" class="py-16 sm:py-20">
  <div class="mx-auto w-full max-w-[1170px] px-5">
    <h2 class="font-heading text-3xl sm:text-4xl m-0 mb-6 text-main-rose">
      {t("services.title")}
    </h2>
  </div>
  <div
    class="mx-auto w-full max-w-[1170px] px-5 grid gap-7 lg:grid-cols-2 items-start"
  >
    <div>
      <div class="grid gap-2 mt" aria-label="Magazines">
        <button
          type="button"
          data-svc="elle"
          aria-pressed="true"
          class="uppercase text-[clamp(18px,2.4vw,28px)] tracking-[0.06em] text-left cursor-pointer select-none transition-colors
                   aria-pressed:text-[#DFB2B2] aria-pressed:font-semibold aria-[pressed=false]:text-subtle hover:text-ink"
        >
          {t("services.individual")}
        </button>
        <button
          type="button"
          data-svc="vogue"
          aria-pressed="false"
          class="uppercase text-[clamp(18px,2.4vw,28px)] tracking-[0.06em] text-left cursor-pointer select-none transition-colors
                   aria-pressed:text-[#DFB2B2] aria-pressed:font-semibold aria-[pressed=false]:text-subtle hover:text-ink"
        >
          {t("services.content")}
        </button>
        <button
          type="button"
          data-svc="allure"
          aria-pressed="false"
          class="uppercase text-[clamp(18px,2.4vw,28px)] tracking-[0.06em] text-left cursor-pointer select-none transition-colors
                   aria-pressed:text-[#DFB2B2] aria-pressed:font-semibold aria-[pressed=false]:text-subtle hover:text-ink"
        >
          {t("services.film")}
        </button>
        <button
          type="button"
          data-svc="numero"
          aria-pressed="false"
          class="uppercase text-[clamp(18px,2.4vw,28px)] tracking-[0.06em] text-left cursor-pointer select-none transition-colors
                   aria-pressed:text-[#DFB2B2] aria-pressed:font-semibold aria-[pressed=false]:text-subtle hover:text-ink"
        >
          {t("services.family")}
        </button>
        <button
          type="button"
          data-svc="essence"
          aria-pressed="false"
          class="uppercase text-[clamp(18px,2.4vw,28px)] tracking-[0.06em] text-left cursor-pointer select-none transition-colors
                   aria-pressed:text-[#DFB2B2] aria-pressed:font-semibold aria-[pressed=false]:text-subtle hover:text-ink"
        >
          {t("services.gift")}
        </button>
      </div>
    </div>

    <div class="max-w-[620px] lg:max-w-none">
      <div
        class="overflow-hidden bg-white transition-transform duration-200 hover:-translate-y-1"
      >
        <div
          id="services-text"
          class="min-h-[240px] sm:min-h-[280px] transition-opacity duration-200 ease-in-out opacity-100 will-change-[opacity]"
        >
          <h3 class="text-xl sm:text-2xl font-semibold mb-3">
            {svcContent[lang].elle.title}
          </h3>
          <div
            class="text-body leading-relaxed space-y-3"
            set:html={svcContent[lang].elle.body}
          />
        </div>
      </div>
    </div>
  </div>
</section>
<!-- Hidden localized templates for service bodies -->
<div class="hidden">
  <div
    data-svc-template="elle"
    data-title={svcContent[lang].elle.title}
    set:html={svcContent[lang].elle.body}
  />
  <div
    data-svc-template="vogue"
    data-title={svcContent[lang].vogue.title}
    set:html={svcContent[lang].vogue.body}
  />
  <div
    data-svc-template="allure"
