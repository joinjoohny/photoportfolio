---
import { Carousel } from "astro-carousel";
import type { ComponentProps } from "astro/types";
import { Image } from "astro:assets";
import type { galleries } from "../../data/galleries";
import { getLangFromUrl, useTranslations } from "../../i18n/ui";
import GalleryComingSoon from "./GalleryComingSoon.astro";

// Temporary: show a "work in progress" placeholder instead of the photos.
// Flip to false to restore the real gallery grid + carousel.
const comingSoon = true;

type Gallery = (typeof galleries)[number];
interface Props {
  gallery: Gallery;
}

const t = useTranslations(Astro);
const lang = getLangFromUrl(Astro.url);
const { gallery } = Astro.props;
const images = gallery.slides.map((s) => ({
  src: s.src,
  alt: s.alt,
  width: s.src.width,
  height: s.src.height,
  widths: [400, 800, 1200],
})) as ComponentProps<typeof Carousel>["images"];
const galleryPath = Astro.url.pathname;
const firstPathSegment = galleryPath.split("/").filter(Boolean)[0] ?? "";
const galleryIndexPath = ["en", "de", "ru"].includes(firstPathSegment)
  ? `/${firstPathSegment}/gallery/`
  : "/gallery/";
---

<section id="gallery" class="py-16 sm:py-20">
  <div class="mx-auto w-full max-w-[1170px] px-5">
    <div class="mb-8 flex items-center justify-between gap-4">
      <h1 class="m-0 text-3xl sm:text-4xl text-main-rose">
        {gallery.title[lang]}
      </h1>
      <a
        href={galleryIndexPath}
        class="text-sm tracking-[0.08em] text-[#3a3a3a] opacity-75 transition-opacity hover:opacity-100 focus-visible:outline-[#3e5348]"
      >
        {t("gallery.back")}
      </a>
    </div>
  </div>

  {
    comingSoon ? (
      <GalleryComingSoon />
    ) : (
      <>
        <div class="w-full px-3 sm:px-5">
          <div id="carouselTargetList" class="portfolio-gallery">
            {gallery.slides.map((s, i) => (
              <a
                href={`${galleryPath}?image=${i}`}
                class="portfolio-gallery__item group"
                data-carousel-index={i}
                aria-label={`${t("portfolio.title")} ${s.code}`}
              >
                <Image
                  src={s.src}
                  alt={s.alt}
                  widths={[360, 540, 720, 960, 1200]}
                  sizes="(max-width: 639px) 100vw, (max-width: 1023px) 33vw, (max-width: 1439px) 25vw, 20vw"
                  class="block h-auto w-full transition-transform duration-300 ease-out group-hover:scale-[1.018]"
                  loading={i < 3 ? "eager" : "lazy"}
                  fetchpriority={i === 0 ? "high" : "auto"}
                  decoding="async"
                />
                <span class="pointer-events-none absolute bottom-0 left-0 right-0 translate-y-2 bg-gradient-to-t from-black/45 to-transparent px-4 pb-3 pt-10 text-[11px] tracking-[0.14em] text-white opacity-0 transition duration-300 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100">
                  {s.code}
                </span>
              </a>
            ))}
          </div>
        </div>

        <Carousel images={images} color="#3e5348" />
      </>
    )
  }
</section>

<style>
  .portfolio-gallery {
    column-count: 1;
    column-gap: 12px;
  }

  .portfolio-gallery__item {
    position: relative;
    display: block;
    margin-bottom: 12px;
    break-inside: avoid;
    overflow: hidden;
    background: #f5f3f1;
    outline: 1px solid transparent;
    outline-offset: -1px;
    transition:
      outline-color 200ms ease,
      opacity 200ms ease;
  }

  .portfolio-gallery__item:focus-visible {
    outline-color: #3e5348;
  }

  @media (min-width: 640px) {
    .portfolio-gallery {
      column-count: 3;
      column-gap: 14px;
    }

    .portfolio-gallery__item {
      margin-bottom: 14px;
    }
  }

  @media (min-width: 1024px) {
    .portfolio-gallery {
      column-count: 4;
      column-gap: 16px;
    }

    .portfolio-gallery__item {
      margin-bottom: 16px;
    }
  }

  @media (min-width: 1440px) {
    .portfolio-gallery {
      column-count: 5;
    }
  }

  :global(.carousel),
  :global(.slides) {
    z-index: 21 !important;
  }
</style>
