---
import { useTranslations, getLangFromUrl } from "../i18n/ui";
import LangSwitcher from "./LangSwitcher.astro";
import { bookingTerms } from "../i18n/content";
import { galleries } from "../data/galleries";
const t = useTranslations(Astro);
const lang = getLangFromUrl(Astro.url);
const galleryBase = lang === "en" ? "/gallery" : `/${lang}/gallery`;
const currentPath = Astro.url.pathname.replace(/\/+$/, "");
const activeSlug =
  galleries.find(
    (gallery) => currentPath === `${galleryBase}/${gallery.slug}`,
  )?.slug ?? null;

// Home page: "" for en, "/de"/"/ru" for others. Anchor links scroll in-page on
// the home page, but jump to the home page (with hash) from anywhere else.
const homeBase = lang === "en" ? "" : `/${lang}`;
const homeUrl = homeBase || "/";
const isHome = currentPath === homeBase;
const anchor = (id: string) => (isHome ? `#${id}` : `${homeBase}/#${id}`);

// "Book me" CTA → opens the Telegram chat with a localized prefilled message.
const bookUrl = `https://t.me/vladisssllava?text=${encodeURIComponent(
  t("book.message"),
)}`;
---

<header
  id="site-header"
  data-home={isHome ? "true" : "false"}
  class:list={[
    "top-0 inset-x-0 z-30 transition-colors duration-300",
    isHome ? "fixed" : "sticky bg-[#fff] backdrop-saturate-150 backdrop-blur",
  ]}
>
  <div
    class="mx-auto w-full max-w-[1170px] px-5 flex items-center justify-between py-4"
  >
    <a
      href={homeUrl}
      class="logo block leading-none text-main-rose"
      aria-label="Vlada Polianskaya"
    >
      <span class="block font-heading text-[22px] font-medium tracking-[0.01em]"
        >Vlada<span class="text-main-green">.</span></span
      >
      <span
        class="mt-[3px] block font-display text-[9.5px] uppercase tracking-[0.34em] text-main-green"
        >Polyanskaya</span
      >
    </a>

    <!-- Toggle (CSS-only via peer) -->
    <label
      for="nav-toggle"
      class="lg:hidden cursor-pointer p-2 -m-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#3e5348] focus:ring-offset-2"
      aria-label="Menu"
      aria-controls="site-nav"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="burger w-7 h-7 text-ink"
        ><path d="M3 6h18M3 12h18M3 18h18"></path></svg
      >
    </label>
    <input id="nav-toggle" type="checkbox" class="peer hidden" />

    <nav
      id="site-nav"
      aria-label="Main navigation"
      class="absolute left-0 right-0 top-full bg-[#fff] border-t border-b border-[#e6e6e6] shadow-[0_10px_30px_rgba(0,0,0,0.06)] opacity-0 -translate-y-2 pointer-events-none transition-opacity transition-transform duration-200 ease-out peer-checked:opacity-100 peer-checked:translate-y-0 peer-checked:pointer-events-auto lg:static lg:opacity-100 lg:translate-y-0 lg:pointer-events-auto lg:shadow-none lg:border-none lg:bg-transparent lg:transition-none lg:duration-0 motion-reduce:transition-none"
    >
      <ul
        class="flex flex-col lg:flex-row lg:items-center lg:gap-7 m-0 p-0 list-none"
      >
        <li class="border-t first:border-t-0 border-[#e6e6e6] lg:border-0">
          <a
            href={anchor("about")}
            class="nav-link block px-5 py-4 lg:px-0 lg:py-2 font-medium text-[14px] tracking-[0.04em] active:bg-[#f2f0e6] lg:active:bg-transparent"
            >{t("nav.about")}</a
          >
        </li>
        <li
          class="group relative border-t first:border-t-0 border-[#e6e6e6] lg:border-0"
        >
          <a
            href={galleryBase}
            aria-haspopup="true"
            class:list={[
              "nav-link flex items-center gap-1.5 px-5 py-4 lg:px-0 lg:py-2 font-medium text-[14px] tracking-[0.04em] active:bg-[#f2f0e6] lg:active:bg-transparent",
              activeSlug && "is-active",
            ]}
          >
            {t("nav.portfolio")}
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-3.5 w-3.5 transition-transform duration-200 lg:group-hover:rotate-180"
              aria-hidden="true"
            >
              <path d="M6 9l6 6 6-6"></path>
            </svg>
          </a>
          <ul
            class="submenu m-0 list-none p-0 lg:invisible lg:absolute lg:left-0 lg:top-full lg:min-w-[230px] lg:-translate-y-1 lg:rounded-md lg:border lg:border-[#e6e6e6] lg:bg-white lg:pt-2 lg:pb-2 lg:opacity-0 lg:shadow-[0_10px_30px_rgba(0,0,0,0.08)] lg:transition lg:duration-200 lg:before:absolute lg:before:-top-3 lg:before:left-0 lg:before:h-3 lg:before:w-full lg:before:content-[''] lg:group-hover:visible lg:group-hover:translate-y-0 lg:group-hover:opacity-100 lg:group-focus-within:visible lg:group-focus-within:translate-y-0 lg:group-focus-within:opacity-100"
          >
            {
              galleries.map((gallery) => (
                <li>
                  <a
                    href={`${galleryBase}/${gallery.slug}/`}
                    aria-current={gallery.slug === activeSlug ? "page" : undefined}
                    class:list={[
                      "nav-link block px-8 py-3 text-[14px] tracking-[0.04em] active:bg-[#f2f0e6] lg:px-4 lg:py-2 lg:active:bg-transparent",
                      gallery.slug === activeSlug && "is-active",
                    ]}
                  >
                    {gallery.title[lang]}
                  </a>
                </li>
              ))
            }
          </ul>
        </li>
        <li class="border-t first:border-t-0 border-[#e6e6e6] lg:border-0">
          <a
            href={anchor("services")}
            class="nav-link block px-5 py-4 lg:px-0 lg:py-2 font-medium text-[14px] tracking-[0.04em] active:bg-[#f2f0e6] lg:active:bg-transparent"
            >{t("nav.services")}</a
          >
        </li>
        <li class="border-t first:border-t-0 border-[#e6e6e6] lg:border-0">
          <a
            href={anchor("contacts")}
            class="nav-link block px-5 py-4 lg:px-0 lg:py-2 font-medium text-[14px] tracking-[0.04em] active:bg-[#f2f0e6] lg:active:bg-transparent"
            >{t("nav.contacts")}</a
          >
        </li>
        <li class="border-t first:border-t-0 border-[#e6e6e6] lg:border-0">
          <a
            href="#"
            id="nav-booking-terms"
            class="nav-link block px-5 py-4 lg:px-0 lg:py-2 font-medium text-[14px] tracking-[0.04em] active:bg-[#f2f0e6] lg:active:bg-transparent"
            >{t("nav.booking")}</a
          >
        </li>
        <li class="border-t first:border-t-0 border-[#e6e6e6] lg:border-0 lg:ml-2">
          <a
            href={bookUrl}
            target="_blank"
            rel="noopener"
            class="book-cta relative mx-auto my-3 flex w-fit items-center justify-center gap-2 rounded-full border-[1.5px] border-main-green bg-transparent px-5 py-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-main-green no-underline transition-colors duration-200 hover:bg-main-green hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#3e5348]/40 lg:mx-0 lg:my-0 lg:w-auto lg:px-4 lg:py-2"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="book-icon h-4 w-4"
              aria-hidden="true"
            >
              <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path>
              <circle cx="12" cy="13" r="3"></circle>
            </svg>
            {t("nav.book")}
          </a>
        </li>
        <li
          class="border-t first:border-t-0 border-[#e6e6e6] lg:border-0 lg:ml-4"
        >
          <LangSwitcher />
        </li>
      </ul>
    </nav>
  </div>
</header>

<!-- Booking Terms Modal -->
<div id="topbar-modal" class="fixed inset-0 z-50 hidden" aria-hidden="true">
  <div id="topbar-modal-backdrop" class="absolute inset-0 bg-black/50"></div>
  <div
    class="relative mx-auto my-8 max-w-[900px] px-5"
    role="dialog"
    aria-modal="true"
    aria-labelledby="topbar-modal-title"
  >
    <div class="bg-white rounded-md shadow-xl overflow-hidden">
      <div
        class="flex items-center justify-between px-5 py-4 border-b border-[#eee]"
      >
        <h3 id="topbar-modal-title" class="text-xl font-semibold m-0">
          {t("modal.bookingTitle")}
        </h3>
        <button
          id="topbar-modal-close"
          type="button"
          class="inline-flex items-center justify-center text-muted hover:text-ink transition-colors"
          aria-label="Close"
        >
          ✕
        </button>
      </div>
      <div
        id="topbar-modal-content"
        class="px-5 py-5 leading-relaxed text-body overflow-y-auto max-h-[75vh]"
      >
      </div>
    </div>
  </div>
</div>

<!-- Hidden booking terms template (localized) -->
<div id="booking-terms-template" class="hidden" set:html={bookingTerms[lang]} />

<script is:inline>
  function initTopbar() {
    const btn = document.getElementById("nav-booking-terms");
    const toggle = document.getElementById("nav-toggle");
    // Modal refs
    const modal = document.getElementById("topbar-modal");
    const modalContent = document.getElementById("topbar-modal-content");
    const modalClose = document.getElementById("topbar-modal-close");
    const modalBackdrop = document.getElementById("topbar-modal-backdrop");

    function openModal() {
      if (!modal || !modalContent) return;
      const tpl = document.getElementById("booking-terms-template");
      const html = tpl ? tpl.innerHTML : "";
      modalContent.innerHTML = `<div class=\"text-body leading-relaxed space-y-3\">${html}</div>`;
      modal.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }
    function closeModal() {
      if (!modal) return;
      modal.classList.add("hidden");
      document.body.style.overflow = "";
    }

    modalClose?.addEventListener("click", closeModal, { passive: true });
    modalBackdrop?.addEventListener("click", closeModal, { passive: true });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal?.classList.contains("hidden"))
        closeModal();
    });

    if (btn) {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        // close mobile menu if open
        if (toggle && toggle.checked) toggle.checked = false;
        openModal();
      });
    }
  }
  document.addEventListener("astro:page-load", initTopbar);
  document.addEventListener("astro:after-swap", initTopbar);
  document.addEventListener("DOMContentLoaded", initTopbar);

  // Transparent-over-hero header → turns solid once the hero is mostly
  // scrolled past. Only active on the home page (data-home="true").
  let headerScrollBound = false;
  function updateHeaderSolid() {
    const h = document.getElementById("site-header");
    if (!h || h.dataset.home !== "true") return;
    h.classList.toggle("is-solid", window.scrollY > window.innerHeight * 0.7);
  }
  function initHeaderScroll() {
    updateHeaderSolid();
    if (headerScrollBound) return;
    window.addEventListener("scroll", updateHeaderSolid, { passive: true });
    window.addEventListener("resize", updateHeaderSolid, { passive: true });
    headerScrollBound = true;
  }
  document.addEventListener("astro:page-load", initHeaderScroll);
  document.addEventListener("astro:after-swap", initHeaderScroll);
  document.addEventListener("DOMContentLoaded", initHeaderScroll);
</script>

<style>
  /* Minimal, elegant fade effect */
  .nav-link {
    color: var(--color-muted);
    opacity: 1;
    /* Editorial uppercase label nav (variant A), matching section labels. */
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    transition:
      color 180ms ease,
      opacity 180ms ease;
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-ink);
    opacity: 1;
    outline: none;
  }
  .nav-link.is-active {
    color: var(--color-main-rose);
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-link {
      transition: none;
    }
  }

  /* Transparent header overlaying the hero (home page, before scroll):
     the whole logo + hamburger turn white over the photo. */
  #site-header[data-home="true"]:not(.is-solid) .logo,
  #site-header[data-home="true"]:not(.is-solid) .logo *,
  #site-header[data-home="true"]:not(.is-solid) .burger {
    color: #fff;
    text-shadow:
      0 1px 3px rgba(0, 0, 0, 0.65),
      0 0 18px rgba(0, 0, 0, 0.5);
  }
  /* Over the hero the Book me CTA is a white hairline outline that fills
     white (with dark text) on hover; on the solid header it's the green
     outline → green fill defined by its utility classes. */
  #site-header[data-home="true"]:not(.is-solid) .book-cta {
    border-color: rgba(255, 255, 255, 0.85);
    color: #fff;
    background-color: transparent;
  }
  #site-header[data-home="true"]:not(.is-solid) .book-cta:hover {
    border-color: #fff;
    background-color: #fff;
    color: #1a1a1a;
  }
  /* Solid header once scrolled (home page). */
  #site-header.is-solid {
    background-color: #fff;
    backdrop-filter: saturate(1.5) blur(8px);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.05);
  }
  /* Smooth white→gray fade for the lang button, matching the nav links.
     :global() is required because the button lives in LangSwitcher. */
  #site-header :global(#lang-button) {
    transition: color 180ms ease;
  }
  /* Desktop nav + lang button also go white over the hero. (On mobile the
     links live inside a white dropdown, so they stay dark.) */
  @media (min-width: 1024px) {
    #site-header[data-home="true"]:not(.is-solid) .nav-link {
      color: #fff;
      opacity: 1;
      text-shadow:
      0 1px 3px rgba(0, 0, 0, 0.65),
      0 0 18px rgba(0, 0, 0, 0.5);
    }
    #site-header[data-home="true"]:not(.is-solid) .nav-link:hover,
    #site-header[data-home="true"]:not(.is-solid) .nav-link:focus-visible {
      color: #fff;
      opacity: 1;
    }
    #site-header[data-home="true"]:not(.is-solid) :global(#lang-button) {
      color: #fff;
      text-shadow:
      0 1px 3px rgba(0, 0, 0, 0.65),
      0 0 18px rgba(0, 0, 0, 0.5);
    }
    /* The Portfolio dropdown opens on a white panel, so its links must
       stay dark even while the header is transparent over the hero. */
    #site-header[data-home="true"]:not(.is-solid) .submenu .nav-link {
      color: var(--color-body);
      opacity: 0.85;
      text-shadow: none;
    }
    #site-header[data-home="true"]:not(.is-solid) .submenu .nav-link:hover,
    #site-header[data-home="true"]:not(.is-solid) .submenu .nav-link:focus-visible {
      color: var(--color-ink);
      opacity: 1;
    }
    #site-header[data-home="true"]:not(.is-solid) .submenu .nav-link.is-active {
      color: var(--color-main-rose);
      opacity: 1;
    }
  }
</style>
