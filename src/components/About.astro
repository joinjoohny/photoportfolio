---
import { Image } from "astro:assets";
import { getAboutPhoto } from "../data/galleryPhotos";
import { useTranslations, getLangFromUrl } from "../i18n/ui";
import { aboutBody } from "../i18n/content";
const t = useTranslations(Astro);
const lang = getLangFromUrl(Astro.url);
const aboutPhoto = getAboutPhoto();
---

<section id="about" class="py-16 sm:py-20">
  <div class="mx-auto w-full max-w-[1170px] px-5">
    <div class="grid lg:grid-cols-[1fr_0.3fr] items-stretch">
      <div class="flex flex-col justify-between">
        <h1
          class="m-0 mb-6 tracking-[0.06em] text-3xl sm:text-4xl text-main-rose lg:text-left"
        >
          {t("about.title")}
        </h1>
        <div class="text-[#3a3a3a] max-w-prose space-y-2" set:html={aboutBody[lang]} />
      </div>

      {
        aboutPhoto && (
          <div class="overflow-hidden max-h-[580px] order-first lg:order-none max-w-[520px] lg:max-w-none mx-auto lg:mx-0 mb-6 lg:mb-0">
            <Image
              src={aboutPhoto.src}
              alt={aboutPhoto.alt}
              widths={[360, 540, 720, 1080]}
              sizes="(min-width: 1024px) 360px, min(520px, 100vw)"
              width={1080}
              class="w-full h-full object-cover"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        )
      }
    </div>
  </div>
</section>
